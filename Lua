                    pcall(function()
                        if statusLbl then
                            statusLbl.Text = "Target moved, switching..."
                            statusLbl.TextColor3 = Color3.fromRGB(255, 165, 0)
                        end
                        if targetLbl then targetLbl.Text = "Target: —" end
                    end)
                    task.wait(0.1)
                    break
                end

                myR.CFrame = CFrame.new(tRoot.Position)
                AutoEquipPunch()
