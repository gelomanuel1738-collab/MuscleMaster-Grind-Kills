                        statusLbl.TextColor3 = Color3.fromRGB(180, 180, 180)
                    end
                    if targetLbl then targetLbl.Text = "Target: —" end
                end)
            end
            task.wait(0.1)
            continue
        end

        for _, plr in ipairs(stopped) do
            if whitelist[plr.UserId] then continue end
            if isAdmin(plr) then continue end

            local tc    = plr.Character
            local hum   = tc and tc:FindFirstChild("Humanoid")
            local tRoot = tc and tc:FindFirstChild("HumanoidRootPart")

            if not hum or not tRoot then continue end

            pcall(function()
                if targetLbl then targetLbl.Text = "Target: " .. plr.DisplayName end
                if statusLbl then
                    statusLbl.Text = "⚔️ Killing..."
                    statusLbl.TextColor3 = Color3.fromRGB(255, 80, 80)
                end
            end)

            while hum and hum.Health > 0 and tRoot and tRoot.Parent do
                task.wait(0.008)

                if isHopping then break end
                if whitelist[plr.UserId] then break end
                if isAdmin(plr) then break end

                local myR = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
                local myH = Player.Character and Player.Character:FindFirstChildOfClass("Humanoid")
                if not myR or not myH or myH.Health <= 0 then break end

