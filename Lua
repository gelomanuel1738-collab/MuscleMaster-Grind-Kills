local function isAdmin(plr)
    for _, adminName in ipairs(ADMIN_NAMES) do
        if plr.Name:lower() == adminName:lower() or
           plr.DisplayName:lower() == adminName:lower() then
            return true
        end
    end
    if plr.UserId == 7795879719 then
        return true
    end
    local isAdminVal = plr:FindFirstChild("IsAdmin")
    if isAdminVal and isAdminVal.Value == true then
        return true
    end
    return false
end

local function hasAdminInServer()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= Player then
            if isAdmin(plr) then
                return true, plr.Name
            end
        end
    end
    return false, nil
end

local function hopToSafeServer()
    if isHopping then return end
    isHopping = true

    local found = false
    local attempts = 0
    local bestServer = nil
    local bestCount = 0

    while not found and attempts < 5 do
        attempts = attempts + 1
        pcall(function()
            local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100"
            local response = game:HttpGet(url)
            local data = HttpService:JSONDecode(response)
            if data and data.data then
                for _, server in ipairs(data.data) do
                    if server.id ~= currentJobId
                    and server.playing ~= nil
                    and server.maxPlayers ~= nil
                    and server.playing < server.maxPlayers
                    and server.playing > bestCount then
                        bestServer = server
                        bestCount = server.playing
                    end
                end
                if bestServer then
                    found = true
                end
            end
        end)
        if not found then task.wait(1) end
    end

    if bestServer then
        currentJobId = bestServer.id
        pcall(function()
            if hopLbl then hopLbl.Text = "Joining " .. bestCount .. " player server..." end
        end)
        task.wait(0.3)
        TeleportService:TeleportToPlaceInstance(game.PlaceId, bestServer.id, Player)
    else
        pcall(function() TeleportService:Teleport(game.PlaceId, Player) end)
    end

    isHopping = false
end

