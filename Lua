-- Track kills
local trackedPlayers = {}

local function trackPlayer(plr)
    if plr == Player then return end
    if trackedPlayers[plr] then return end
    trackedPlayers[plr] = true

    plr.CharacterAdded:Connect(function(char)
        local hum = char:WaitForChild("Humanoid")
        hum.Died:Connect(function()
            if not whitelist[plr.UserId] then
                sessionKills = sessionKills + 1
                killLbl.Text = "Total Kills: " .. sessionKills
            end
        end)
    end)

    if plr.Character then
        local hum = plr.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.Died:Connect(function()
                if not whitelist[plr.UserId] then
                    sessionKills = sessionKills + 1
                    killLbl.Text = "Total Kills: " .. sessionKills
                end
            end)
        end
    end
end

for _, plr in ipairs(Players:GetPlayers()) do
    task.spawn(function() trackPlayer(plr) end)
end
Players.PlayerAdded:Connect(function(plr)
    task.spawn(function() trackPlayer(plr) end)
end)
Players.PlayerRemoving:Connect(function(plr)
    trackedPlayers[plr] = nil
end)

